{
  "name": "odul-katalog-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "pages:build": "opennextjs-cloudflare build",
    "pages:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "pages:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "npm run pages:preview",
    "deploy": "npm run pages:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "wrangler": "4.110.0"
  }
}
